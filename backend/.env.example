# ALLOWED_ORIGINS controls which website domains are allowed to call this backend's API (CORS).
# Set this to the exact domain(s) where the chatbot widget is embedded, comma-separated if more than one.
# Example: ALLOWED_ORIGINS=https://yourcollege.edu,https://www.yourcollege.edu
# Leaving this unset defaults to "*" (any domain allowed) — fine for local dev, NOT recommended once deployed.
ALLOWED_ORIGINS=
